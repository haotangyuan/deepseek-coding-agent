{
  "name": "deepseek-coding-agent",
  "version": "0.1.0",
  "description": "A lightweight DeepSeek-first coding agent built on Pi",
  "type": "module",
  "private": true,
  "bin": {
    "deepseek-code": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "start": "node --env-file-if-exists=.env dist/main.js",
    "eval": "node --env-file-if-exists=.env dist/eval.js"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.80.7",
    "@earendil-works/pi-tui": "0.80.7"
  },
  "devDependencies": {
    "@types/node": "24.12.4",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haotangyuan/deepseek-coding-agent.git"
  },
  "keywords": [
    "coding-agent",
    "deepseek",
    "pi",
    "cli",
    "agent"
  ]
}
